#compdef cmux-msg
#
# cmux-msg のサブコマンド + 主要オプションの補完。
# 動的補完 (peer 一覧 / inbox filename) は cmux-msg 自体を呼ぶと
# 依存ループするため固定補完のみ。

local -a subcommands
subcommands=(
  'init:メッセージディレクトリを初期化'
  'whoami:自分のID情報を表示'
  'peers:peer 一覧 (軸明示必須)'
  'ls-peers:peers のエイリアス'
  'send:メッセージ送信 (永続)'
  'broadcast:軸を明示してブロードキャスト'
  'list:inbox のメッセージ一覧'
  'ls:list のエイリアス'
  'read:メッセージ内容を表示'
  'accept:メッセージを受理'
  'dismiss:メッセージを破棄'
  'reply:返信送信 & アーカイブ'
  'subscribe:inbox 新着を JSONL で連続出力'
  'check-subscribe:subscribe 稼働判定'
  'notify:軽量通知 (subscribe stream に本文同梱)'
  'label:自セッションに label 貼り剥がし'
  'history:時系列マージで全メッセージ表示'
  'thread:in_reply_to を辿って会話単位で表示'
  'gc:dead セッション dir の掃除'
  'help:ヘルプ表示'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args'

case "$state" in
  subcommand)
    _describe -t commands 'cmux-msg subcommand' subcommands
    ;;
  args)
    case "$words[1]" in
      peers|ls-peers)
        _arguments \
          '*--by[グルーピング軸 (home/cwd/repo/tag:NAME)]:axis:(home cwd repo)' \
          '--all[alive な全 peer (軸無視、明示)]' \
          '--include-dead[dead な peer も表示]' \
          '--verbose[補助情報も出力]' \
          '-v[補助情報も出力]'
        ;;
      broadcast)
        _arguments \
          '*--by[グルーピング軸 (home/cwd/repo/tag:NAME)]:axis:(home cwd repo)' \
          '--all[alive な全 peer (軸無視、明示)]' \
          '--text[本文 (stdin の代替)]:text'
        ;;
      send)
        _arguments \
          '--text[本文 (stdin の代替)]:text'
        ;;
      reply)
        _arguments \
          '--text[本文 (stdin の代替)]:text'
        ;;
      notify)
        _arguments \
          '--to[宛先 session_id]:session_id' \
          '--self[自セッション宛 (= to == from)]' \
          '--text[本文 (stdin の代替)]:text'
        ;;
      subscribe)
        _arguments \
          '--force[前 subscribe を SIGTERM → grace → SIGKILL で奪取]'
        ;;
      label)
        _arguments \
          '1:action:(add remove list)'
        ;;
      history)
        _arguments \
          '--peer[相手 session_id でフィルタ]:session_id' \
          '--limit[件数制限]:N' \
          '--json[構造化出力]'
        ;;
      thread)
        _arguments \
          '--json[構造化出力]'
        ;;
      gc)
        _arguments \
          '--force[実削除 (default: dry-run)]' \
          '--verbose[保持理由を全件表示]'
        ;;
    esac
    ;;
esac
