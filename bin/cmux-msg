#!/usr/bin/env bash
# cmux-msg shell wrapper
#
# cmux-msg は bun で TypeScript (src/cli.ts) を直接実行する方式に一本化されている。
# コンパイル済みバイナリは廃止したため、bun が必須要件。
# CC 側 hook も shell ユーザもこのスクリプト 1 つを呼べばよい。
#
# zsh/bash/fish 等から alias で指せば PATH を汚さずに使える。

__here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
__src="${__here}/../src/cli.ts"

if command -v bun >/dev/null 2>&1; then
  exec bun run "$__src" "$@"
else
  echo "cmux-msg: bun が見つかりません。bun をインストールしてください。" >&2
  echo "  https://bun.sh/" >&2
  exit 1
fi
